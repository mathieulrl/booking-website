# MongoDB connection string (Atlas recommended). Create a free cluster at mongodb.com/atlas.
MONGODB_URI="mongodb+srv://user:password@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority"

# Database name (optional, defaults to london_booking)
MONGODB_DB="london_booking"

# Shared access code you hand out to your family (lets them book)
ACCESS_CODE="change-me"

# Admin code (only you). Logging in with this code lets you cancel bookings.
ADMIN_CODE="change-me-too"

# Secret used to sign the session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET="generate-a-long-random-value"

# Email (optional). Get an API key at resend.com. Without these, no email is sent.
RESEND_API_KEY=""
# Where booking notifications are sent (your inbox). In Resend test mode this MUST
# be the email of your Resend account, otherwise nothing is delivered.
ADMIN_EMAIL=""
# Sender address. Test mode: keep onboarding@resend.dev. With a verified domain,
# use e.g. "Emma & Mathieu's Hôtel <bonjour@your-domain.com>".
EMAIL_FROM="Emma & Mathieu's Hôtel <onboarding@resend.dev>"
# Public URL of the deployed site, used to show the photo in the confirmation
# email (e.g. https://your-app.vercel.app). Without it, the email has no photo.
SITE_URL=""
